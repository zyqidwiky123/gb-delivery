{
  "auth": {
    "authorizedDomains": [
      "aro-drive-user.web.app",
      "aro-drive-driver.web.app",
      "aro-drive-admin.web.app",
      "gb-delivery-41bf6.web.app",
      "localhost"
    ],
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "ARO DRIVE",
        "supportEmail": "zyqidwiky@gmail.com",
        "authorizedRedirectUris": [
          "https://aro-drive-user.web.app",
          "https://aro-drive-driver.web.app",
          "https://aro-drive-admin.web.app",
          "https://gb-delivery-41bf6.web.app",
          "http://localhost:5173",
          "http://localhost:4000"
        ]
      }
    }
  },
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "site": "gb-delivery-41bf6",
      "public": "aro-landing-page",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ]
    },
    {
      "site": "aro-drive-user",
      "public": "aro-drive-vite/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "site": "aro-drive-driver",
      "public": "aro-drive-driver-vite/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "site": "aro-drive-admin",
      "public": "aro-admin-vite/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-functions-test"
      ]
    }
  ]
}
